# Template for /etc/paysats/mcp.env on the VPS that runs paysats-mcp.service.
# Install with:
#   sudo install -d -o root -g vibhav -m 750 /etc/paysats
#   sudo install -m 640 -o root -g vibhav \
#     deploy/paysats-mcp.env.example /etc/paysats/mcp.env
#   sudo $EDITOR /etc/paysats/mcp.env  # paste real PAYSATS_API_KEY
#
# WARNING: PAYSATS_MCP_PUBLIC_MODE=true means anyone with the public URL can
# call all tools (including create_offramp_order, which mints Lightning
# invoices and triggers IDR payouts) using the held PAYSATS_API_KEY. Use a
# DEDICATED tenant for this key so it can be revoked independently via
# `npm --prefix backend run key:revoke`.

# Held tenant key minted via:
#   npm --prefix backend run tenant:create -- \
#     --name "PaySats public MCP" --label "hosted-public"
PAYSATS_API_KEY=pk_live_...replace_me

# Backend lives on the same VPS — keep the SDK->backend hop on loopback.
PAYSATS_BASE_URL=http://127.0.0.1:8080

# HTTP transport, bound to localhost; nginx terminates TLS in front.
PAYSATS_MCP_TRANSPORT=http
PAYSATS_MCP_HOST=127.0.0.1
PAYSATS_MCP_PORT=3333

# Public single-URL mode: drops bearer requirement, defaults rate limit to 30.
PAYSATS_MCP_PUBLIC_MODE=true

# DNS-rebinding / unexpected-Host protection. Must match the nginx server_name.
PAYSATS_MCP_ALLOWED_HOSTS=mcp.paysats.exchange

# Per-IP rate limit (req/min). Trust-proxy is on so this keys off the real
# client IP, not 127.0.0.1.
PAYSATS_MCP_RATE_LIMIT_PER_MINUTE=30

PAYSATS_MCP_LOG_LEVEL=info
